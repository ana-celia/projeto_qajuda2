{
    "name": "QAjuda Full Stack",
    // CORREÇÃO AQUI: Apontamos para a pasta backend onde o arquivo realmente está
    "dockerComposeFile": "../backend/docker-compose.yml",
    "service": "django",
    "workspaceFolder": "/app/backend",
    
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-python.debugpy",
                "dbaeumer.vscode-eslint",
                "esbenp.prettier-vscode",
                "ms-vscode.docker",
                "eamodio.gitlens",
                "batisteo.vscode-django"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python",
                "editor.formatOnSave": true,
                "python.linting.enabled": true,
                "python.linting.pylintEnabled": true
            }
        }
    },
    
    "features": {
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/devcontainers/features/node:1": {
            "nodeVersion": "20"
        }
    },

    "remoteUser": "root",
    "postCreateCommand": "python3 manage.py migrate" 
}